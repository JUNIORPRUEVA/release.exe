PORT=3000
APP_BASE_URL=http://localhost:3000
MAX_UPLOAD_SIZE=500mb
UPLOAD_TMP_DIR=storage/tmp

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=version_manager
DB_SYNCHRONIZE=true

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=replace-this-secret
JWT_EXPIRES_IN=12h

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=storage/uploads

# S3-compatible storage. Cloudflare R2 can use either the S3_* names below
# or the equivalent R2_* aliases if you prefer that naming style.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PREFIX=uploads
S3_FORCE_PATH_STYLE=true

R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_PREFIX=uploads
R2_FORCE_PATH_STYLE=true

DIRECT_UPLOAD_ENABLED=true
DIRECT_UPLOAD_URL_EXPIRES_SECONDS=900
